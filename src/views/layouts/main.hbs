<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sistema de Citas Médicas</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
  <style>
    :root {
      --primary: #1a6b5a;
      --primary-light: #2a8f76;
      --accent: #e8f5f1;
      --gold: #c9a84c;
      --dark: #0f2d26;
      --text: #1e3a34;
      --muted: #6b8f87;
      --surface: #ffffff;
      --border: #d4e8e2;
    }

    * { box-sizing: border-box; }

    body {
      font-family: 'DM Sans', sans-serif;
      background: #f4f9f7;
      color: var(--text);
      min-height: 100vh;
    }

    /* FIGURAS ANIMADAS */
    .bg-shapes {
      position: fixed;
      top: 0; left: 0;
      width: 100%; height: 100%;
      pointer-events: none;
      z-index: 0;
      overflow: hidden;
    }

    .shape {
      position: absolute;
      border-radius: 50%;
      opacity: 0.15;
    }

    .shape-1 {
      width: 300px; height: 300px;
      background: var(--primary);
      top: -80px; left: -80px;
      animation: float1 8s ease-in-out infinite;
    }

    .shape-2 {
      width: 200px; height: 200px;
      background: var(--gold);
      top: 20%; right: -60px;
      border-radius: 30% 70% 70% 30% / 30% 30% 70% 70%;
      animation: float2 10s ease-in-out infinite;
    }

    .shape-3 {
      width: 150px; height: 150px;
      background: var(--primary-light);
      bottom: 10%; left: 5%;
      animation: float3 7s ease-in-out infinite;
    }

    .shape-4 {
      width: 250px; height: 250px;
      background: var(--gold);
      bottom: -60px; right: 10%;
      border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%;
      animation: float1 12s ease-in-out infinite reverse;
    }

    .shape-5 {
      width: 100px; height: 100px;
      background: var(--primary);
      top: 50%; left: 40%;
      animation: float2 9s ease-in-out infinite 2s;
    }

    .shape-6 {
      width: 180px; height: 180px;
      background: var(--primary-light);
      top: 70%; right: 30%;
      border-radius: 40% 60% 60% 40% / 40% 40% 60% 60%;
      animation: float3 11s ease-in-out infinite 1s;
    }

    @keyframes float1 {
      0%, 100% { transform: translate(0, 0) rotate(0deg); }
      33%       { transform: translate(20px, -30px) rotate(10deg); }
      66%       { transform: translate(-15px, 20px) rotate(-8deg); }
    }

    @keyframes float2 {
      0%, 100% { transform: translate(0, 0) scale(1); }
      50%       { transform: translate(-25px, 30px) scale(1.1); }
    }

    @keyframes float3 {
      0%, 100% { transform: translate(0, 0) rotate(0deg) scale(1); }
      40%       { transform: translate(15px, -20px) rotate(15deg) scale(0.95); }
      80%       { transform: translate(-10px, 10px) rotate(-10deg) scale(1.05); }
    }

    /* NAVBAR */
    .navbar, .main-container {
      position: relative;
      z-index: 1;
    }

    .navbar {
      background: var(--dark) !important;
      border-bottom: 3px solid var(--gold);
      padding: 1rem 0;
    }

    .navbar-brand {
      font-family: 'Playfair Display', serif;
      font-size: 1.4rem;
      color: #fff !important;
      letter-spacing: 0.5px;
    }

    .navbar-brand span {
      color: var(--gold);
    }

    .navbar-toggler {
      border-color: rgba(201,168,76,0.5) !important;
      padding: 0.3rem 0.6rem;
    }

    .navbar-toggler:focus {
      box-shadow: none;
    }

    .nav-link {
      color: rgba(255,255,255,0.75) !important;
      font-size: 0.9rem;
      font-weight: 500;
      letter-spacing: 0.3px;
      padding: 0.4rem 1rem !important;
      border-radius: 6px;
      transition: all 0.2s;
    }

    .nav-link:hover {
      color: #fff !important;
      background: rgba(255,255,255,0.08);
    }

    .nav-link.logout {
      color: var(--gold) !important;
      border: 1px solid rgba(201,168,76,0.3);
    }

    .nav-link.logout:hover {
      background: rgba(201,168,76,0.1);
    }

    /* CONTENIDO */
    .main-container {
      max-width: 1100px;
      margin: 0 auto;
      padding: 2.5rem 1.5rem;
    }

    /* CARDS */
    .card {
      border: 1px solid var(--border);
      border-radius: 16px;
      box-shadow: 0 4px 24px rgba(26,107,90,0.07);
      overflow: hidden;
    }

    .card-header {
      border-bottom: 1px solid var(--border);
      padding: 1.25rem 1.5rem;
    }

    .card-header.verde {
      background: linear-gradient(135deg, var(--primary), var(--primary-light));
      color: white;
    }

    .card-header.dorado {
      background: linear-gradient(135deg, #8a6820, var(--gold));
      color: white;
    }

    /* BOTONES */
    .btn-primary {
      background: var(--primary);
      border-color: var(--primary);
      border-radius: 8px;
      font-weight: 500;
      padding: 0.55rem 1.4rem;
      transition: all 0.2s;
    }

    .btn-primary:hover {
      background: var(--primary-light);
      border-color: var(--primary-light);
      transform: translateY(-1px);
      box-shadow: 0 4px 12px rgba(26,107,90,0.25);
    }

    .btn-success {
      background: #2d7a4f;
      border-color: #2d7a4f;
      border-radius: 8px;
      font-weight: 500;
      padding: 0.55rem 1.4rem;
      transition: all 0.2s;
    }

    .btn-success:hover {
      background: #389861;
      transform: translateY(-1px);
      box-shadow: 0 4px 12px rgba(45,122,79,0.25);
    }

    .btn-warning {
      border-radius: 8px;
      font-weight: 500;
    }

    .btn-danger {
      border-radius: 8px;
      font-weight: 500;
    }

    .btn-secondary {
      border-radius: 8px;
      font-weight: 500;
      background: #e8efed;
      border-color: #e8efed;
      color: var(--text);
    }

    /* INPUTS */
    .form-control, .form-select {
      border: 1.5px solid var(--border);
      border-radius: 8px;
      padding: 0.6rem 0.9rem;
      font-size: 0.95rem;
      transition: border-color 0.2s, box-shadow 0.2s;
    }

    .form-control:focus, .form-select:focus {
      border-color: var(--primary);
      box-shadow: 0 0 0 3px rgba(26,107,90,0.12);
    }

    .form-label {
      font-weight: 500;
      font-size: 0.88rem;
      color: var(--muted);
      text-transform: uppercase;
      letter-spacing: 0.5px;
      margin-bottom: 0.4rem;
    }

    /* TABLA */
    .table {
      border-radius: 12px;
      overflow: hidden;
    }

    .table thead th {
      background: var(--dark);
      color: rgba(255,255,255,0.85);
      font-size: 0.82rem;
      text-transform: uppercase;
      letter-spacing: 0.8px;
      font-weight: 500;
      padding: 1rem;
      border: none;
    }

    .table tbody tr {
      transition: background 0.15s;
    }

    .table tbody tr:hover {
      background: var(--accent);
    }

    .table tbody td {
      padding: 0.9rem 1rem;
      vertical-align: middle;
      border-color: var(--border);
      font-size: 0.95rem;
    }
  </style>
</head>
<body>

  <div class="bg-shapes" aria-hidden="true">
    <div class="shape shape-1"></div>
    <div class="shape shape-2"></div>
    <div class="shape shape-3"></div>
    <div class="shape shape-4"></div>
    <div class="shape shape-5"></div>
    <div class="shape shape-6"></div>
  </div>

  <nav class="navbar navbar-expand-lg">
    <div class="container">
      <a class="navbar-brand" href="/"><span>+</span> Agendador Médico</a>

      <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navMenu">
        <span style="color: var(--gold); font-size: 1.3rem;">☰</span>
      </button>

      <div class="collapse navbar-collapse" id="navMenu">
        <ul class="navbar-nav ms-auto gap-1">
          <li class="nav-item">
            <a class="nav-link" href="/">Inicio</a>
          </li>
          {{#if user}}
            <li class="nav-item">
              <a class="nav-link" href="/citas/add">Agendar Cita</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/citas/list">Ver Citas</a>
            </li>
            <li class="nav-item">
              <a class="nav-link logout" href="/logout">
                Cerrar Sesión ({{user.name}})
              </a>
            </li>
          {{else}}
            <li class="nav-item">
              <a class="nav-link" href="/login">Iniciar Sesión</a>
            </li>
            <li class="nav-item">
              <a class="nav-link" href="/pacientes/addp">Crear Paciente</a>
            </li>
          {{/if}}
        </ul>
      </div>
    </div>
  </nav>

  <div class="main-container">
    {{{body}}}
  </div>

  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>