<style>
  .page-header {
    margin-bottom: 2rem;
  }

  .page-header h2 {
    font-family: 'Playfair Display', serif;
    font-size: 2rem;
    color: var(--dark);
    margin-bottom: 0.3rem;
  }

  .page-header p {
    color: var(--muted);
    font-size: 0.95rem;
  }

  .edit-card {
    max-width: 560px;
  }

  .edit-card .card-header {
    background: linear-gradient(135deg, #8a6820, var(--gold));
    color: white;
    font-family: 'Playfair Display', serif;
    font-size: 1.2rem;
    padding: 1.25rem 1.75rem;
  }

  .edit-card .card-body {
    padding: 2rem 1.75rem;
  }

  .form-actions {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 1.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
  }
</style>

<div class="page-header">
  <h2>Editar Cita</h2>
  <p>Modifica los datos de tu cita médica</p>
</div>

<div class="card edit-card">
  <div class="card-header">
     Modificar Cita
  </div>
  <div class="card-body">
    <form action="/citas/edit/{{cita.id}}" method="POST">

      <div class="mb-3">
        <label class="form-label">Especialidad</label>
        <input type="text" name="especialidad" class="form-control" value="{{cita.especialidad}}" required>
      </div>

      {{#if error}}
      <div class="alert alert-danger" role="alert">
        ⚠️ {{error}}
      </div>
      {{/if}}

      <div class="row g-3 mb-3">
        <div class="col-md-6">
          <label class="form-label">Fecha</label>
          <input type="date" name="fecha" class="form-control" id="fechaInput" value="{{cita.fecha}}" required>
        </div>
        <div class="col-md-6">
          <label class="form-label">Hora</label>
          <input type="time" name="hora" class="form-control" id="horaInput" value="{{cita.hora}}" min="08:00" max="18:00" required>
        </div>
      </div>

      <div class="form-actions">
        <a href="/citas/list" class="btn btn-secondary">← Cancelar</a>
        <button class="btn btn-warning">Actualizar Cita</button>
      </div>

    </form>
  </div>
</div>

<script>
  const fechaInput = document.getElementById('fechaInput');
  const horaInput = document.getElementById('horaInput');

  const hoy = new Date().toISOString().split('T')[0];
  fechaInput.setAttribute('min', hoy);

  function actualizarHora() {
    const fechaSeleccionada = fechaInput.value;

    if (fechaSeleccionada === hoy) {
      const ahora = new Date();
      const hh = String(ahora.getHours()).padStart(2, '0');
      const mm = String(ahora.getMinutes()).padStart(2, '0');
      const horaActual = `${hh}:${mm}`;
      horaInput.setAttribute('min', horaActual < '08:00' ? '08:00' : horaActual);
    } else {
      horaInput.setAttribute('min', '08:00');
    }

    horaInput.setAttribute('max', '18:00');
  }

  fechaInput.addEventListener('change', actualizarHora);
  actualizarHora();
</script>